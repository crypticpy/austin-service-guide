# ── OpenAI (primary AI provider) ──────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5-2026-04-23
OPENAI_REASONING_EFFORT=medium
# Cap on tool-call rounds inside one assistant turn (safety net)
OPENAI_MAX_TOOL_ITERATIONS=6

# ── App behavior ──────────────────────────────────────────────────
# When true, intake uses the scripted fallback regardless of the key.
DEMO_MODE=false

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Azure OpenAI (legacy fallback, optional) ──────────────────────
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
