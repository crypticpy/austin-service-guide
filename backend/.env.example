# ── OpenAI (primary AI provider) ──────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5-2026-04-23
OPENAI_REASONING_EFFORT=medium
# Cap on tool-call rounds inside one assistant turn (safety net)
OPENAI_MAX_TOOL_ITERATIONS=6

# Realtime voice intake (browser uses ephemeral client secrets)
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_REASONING_EFFORT=medium
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_SECRET_TTL_SECONDS=600
# Local troubleshooting trace for Realtime voice sessions. This includes
# short transcript previews, so keep it disabled or protected in production.
REALTIME_DEBUG_LOG_ENABLED=true
REALTIME_DEBUG_LOG_PATH=logs/realtime_debug.jsonl

# ── App behavior ──────────────────────────────────────────────────
# When true, intake uses the scripted fallback regardless of the key.
DEMO_MODE=false

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174

# Public origin used to build shareable URLs (QR codes, SMS/email links)
PUBLIC_ORIGIN=http://localhost:5173

# ── Notifications (optional — stubs out without these) ────────────
# Twilio (SMS): https://console.twilio.com/
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15125551234
# SendGrid (email): https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@austin-service-guide.local
# SENDGRID_FROM_NAME=Austin Service Guide

# ── Azure OpenAI (legacy fallback, optional) ──────────────────────
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
